<%= render FlatPack::Grid::Component.new(
  cols: 1,
  align: :center,
  class: "min-h-screen place-content-center justify-items-center p-4"
) do %>
  <%= render FlatPack::Card::Component.new(style: :default, class: "h-auto w-full max-w-md") do |card| %>
    <% card.header do %>
      <%= render FlatPack::PageTitle::Component.new(
        title: "Sign In",
        variant: :h2,
        class: "mb-0 pb-0"
      ) %>
    <% end %>

    <% card.body do %>
      <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do %>
        <%= render FlatPack::Grid::Component.new(cols: 1, gap: :md) do %>
          <%= render FlatPack::EmailInput::Component.new(
            name: "#{resource_name}[email]",
            label: "Email",
            value: "admin@admin.com",
            placeholder: "you@example.com"
          ) %>

          <%= render FlatPack::PasswordInput::Component.new(
            name: "#{resource_name}[password]",
            label: "Password",
            value: "Password",
            required: true
          ) %>

          <% if devise_mapping.rememberable? %>
            <%= render FlatPack::Checkbox::Component.new(
              name: "#{resource_name}[remember_me]",
              label: "Remember me"
            ) %>
          <% end %>

          <%= render FlatPack::Button::Component.new(
            text: "Sign In",
            style: :primary,
            size: :md,
            type: "submit"
          ) %>
        <% end %>
      <% end %>
    <% end %>

    <% card.footer do %>
      <%= render FlatPack::Badge::Component.new(
        text: "Default: admin@admin.com / Password",
        style: :info,
        size: :sm
      ) %>
    <% end %>
  <% end %>
<% end %>
